<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.giorgio.controllers.MainPageController">

      <VBox spacing="10" style="-fx-padding: 10;">
            <Button text="Main Page" onAction="#backToMain"
                  style="-fx-background-color: black;
                        -fx-border-color: #DDDDDA;
                        -fx-border-radius: 8;
                        -fx-background-radius: 8;
                        -fx-padding: 6 14 6 14;
                        -fx-font-size: 13;
                        -fx-cursor: hand;" />

            <Label fx:id="statusLabelMeshCount"
                   layoutX="20.0"
                   layoutY="20.0"
                   text="Meshes: "
                   style="-fx-font-size: 16px;" />
            <Label fx:id="statusLabelTriangleCount"
                   layoutX="20.0"
                   layoutY="20.0"
                   text="Triangles: "
                   style="-fx-font-size: 16px;" />

            <Label fx:id="LiveFpsCount"
                  layoutX="20.0"
                   layoutY="20.0"
                   text="Fps: "
                   style="-fx-font-size: 16px;" />
            <Label fx:id="currentCamCordsLabel"
                  layoutX="20.0"
                   layoutY="20.0"
                   text="Cam Cords: "
                   style="-fx-font-size: 16px;" />
      </VBox>

      <Region HBox.hgrow="ALWAYS"
        maxWidth="200"/>

      <ImageView fx:id="renderView"
            fitWidth="600"
            fitHeight="600" />

</HBox>